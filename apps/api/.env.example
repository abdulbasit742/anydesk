PORT=5000

# ---- Database ---------------------------------------------------------------
# Local dev (Docker or local PostgreSQL):
DATABASE_URL="postgresql://remotedesk:remotedesk@localhost:5432/remotedesk"
# Supabase free tier — go to supabase.com → project → Settings → Database → URI:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ---- Auth -------------------------------------------------------------------
JWT_SECRET="change-this-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-32-chars"

# ---- CORS -------------------------------------------------------------------
# Add your dashboard URL (Vercel/Lovable) and mobile app origins.
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# ---- WebRTC / TURN ----------------------------------------------------------
# Without TURN: WebRTC only works when both users are on the same network.
# With TURN: works across the internet (firewalls, mobile data, hotel WiFi).
#
# Option A: Self-hosted Coturn on a $5/mo VPS (see C:\RemoteDeskLive\coturn\README.md)
# TURN_URL=turn:YOUR_VPS_IP:3478
# TURN_USERNAME=remotedesk
# TURN_PASSWORD=YOUR_STRONG_PASSWORD
#
# Option B: Twilio TURN — free 100 GB/month (console.twilio.com → Network Traversal)
# TURN_URL=turn:global.turn.twilio.com:3478?transport=udp
# TURN_USERNAME=<twilio_credential_username>
# TURN_PASSWORD=<twilio_credential_password>
#
# Custom STUN (optional — defaults to Google public stun:stun.l.google.com:19302)
# STUN_URL=stun:YOUR_STUN_SERVER:3478

# ---- Beta / Feature Gates ---------------------------------------------------
BETA_SOCKET_ENABLED=true
BETA_WEBRTC_SIGNALING_ENABLED=true

# ---- Local dev without PostgreSQL -------------------------------------------
# Set to true to run the API with a fully in-memory backend (no DB needed).
# All data is lost when the process restarts. NEVER use in production.
DEV_IN_MEMORY_FALLBACK=false

# ---- Stripe (optional billing) ----------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
