PORT=5000
DATABASE_URL="postgresql://remotedesk:remotedesk@localhost:5432/remotedesk"
JWT_SECRET="change-this-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-32-chars"

# Comma-separated list of allowed origins for CORS.
# Add your Lovable/Vercel dashboard URL and any mobile app origins here.
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# ---- Beta / Feature Gates ----
# Socket.IO connections (required for any WebRTC signaling)
BETA_SOCKET_ENABLED=true
# WebRTC signaling relay (offer/answer/ICE exchange)
BETA_WEBRTC_SIGNALING_ENABLED=true

# ---- Local dev without PostgreSQL ----
# Set to true to run the API with a fully in-memory backend (no DB needed).
# All data is lost when the process restarts. NEVER use in production.
DEV_IN_MEMORY_FALLBACK=false

# ---- Stripe (optional billing) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
