generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  fullName         String
  remoteDeskId     String         @unique
  devicePassword   String?
  isOnline         Boolean        @default(false)
  socketId         String?
  lastSeenAt       DateTime?
  plan             Plan           @default(FREE)
  stripeCustomerId String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  devices          Device[]
  issuedCommands   DeviceCommand[] @relation("IssuedDeviceCommands")
  deviceAuditEvents DeviceAuditEvent[] @relation("DeviceAuditActors")
  launchChecks      LaunchCheck[] @relation("LaunchCheckCreators")
  releaseCandidates ReleaseCandidate[] @relation("ReleaseCandidateCreators")
  rolloutApprovals  RolloutApproval[] @relation("RolloutApprovalActors")
  migrationChecks   MigrationCheck[] @relation("MigrationCheckCreators")
  supportEscalationsCreated SupportEscalation[] @relation("SupportEscalationCreators")
  supportEscalationsAssigned SupportEscalation[] @relation("SupportEscalationAssignees")
  connectorInstallations ConnectorInstallation[] @relation("ConnectorInstallationUsers")
  connectorAuditEvents ConnectorAuditEvent[] @relation("ConnectorAuditActors")
  twoFactorSecret  String?
  twoFactorEnabled Boolean        @default(false)
  twoFactorBackupCodes String?
  isAdmin          Boolean        @default(false)
  subscription     Subscription?
  hostSessions     Session[]      @relation("HostSessions")
  clientSessions   Session[]      @relation("ClientSessions")
  accessControlEntries AccessControlEntry[]
  deviceApprovals      DeviceFingerprint[] @relation("DeviceApprovals")
  securityAuditLogs    SecurityAuditLog[] @relation("UserAuditLogs")
  threatAlerts         ThreatAlert[] @relation("UserThreatAlerts")
  supportTickets   SupportTicket[]
  streamingProfiles StreamingProfile[]
  wakeOnLanTargets  WakeOnLanTarget[]
  ownedClusters        Cluster[]       @relation("OwnedClusters")
  clusterNodes         ClusterNode[]   @relation("UserClusterNodes")
  submittedTasks       DistributedTask[] @relation("SubmittedTasks")

  // IoT relations
  iotSites         IoTSite[]
  iotDevices       IoTDevice[]
  iotAlerts        IoTAlert[]
  iotAlertRules    IoTAlertRule[]
  iotTasks         IoTScheduledTask[]
  iotTunnels       IoTTunnel[]
  smartHomeEntities SmartHomeEntity[]

  meshNetworks     MeshNetwork[]

  // Unified Communications
  tickets          Ticket[]       @relation("TicketCustomer")
  assignedTickets  Ticket[]       @relation("TicketAssignee")
  messages         Message[]
  kbArticles       KBArticle[]
  automationRules  AutomationRule[]
  teamChannels     TeamChannel[]  @relation("ChannelCreator")
  channelMemberships TeamChannelMember[]
  cannedResponses  CannedResponse[]
  ivrFlows         IVRFlow[]
  billingUsage     BillingUsage[]   @relation("UserBillingUsage")
  invoices         Invoice[]        @relation("UserInvoices")
  licenseKeys      LicenseKey[]     @relation("UserLicenseKeys")
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  organizationMembers OrganizationMember[] @relation("UserOrganizationMembers")
  remoteShellSessions RemoteShellSession[] @relation("UserRemoteShellSessions")
  dunningRecords   DunningRecord[]  @relation("UserDunningRecords")
  fleetOperations  FleetOperation[] @relation("UserFleetOperations")
  affiliateProfile AffiliateProfile? @relation("UserAffiliateProfile")
  affiliateReferral AffiliateReferral? @relation("ReferredUser")
  deviceGroups     DeviceGroup[]    @relation("UserDeviceGroups")
  universalDevices UniversalDevice[] @relation("UserUniversalDevices")
  unifiedNotifications UnifiedNotification[] @relation("UserUnifiedNotifications")
  screenTimeLogs   ScreenTimeLog[]  @relation("UserScreenTimeLogs")
}

model AccessControlEntry {
  id           String   @id @default(uuid())
  userId       String
  remoteDeskId String
  action       String   @default("block")
  label        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, remoteDeskId])
  @@index([userId, action])
}

model Device {
  id           String   @id @default(uuid())
  userId       String
  name         String
  platform     String
  remoteDeskId String   @unique
  isOnline     Boolean  @default(false)
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commands     DeviceCommand[]
  auditEvents  DeviceAuditEvent[]
  trustRecord  DeviceTrust?
  accessPolicy DeviceAccessPolicy?
  fingerprint  DeviceFingerprint?
  securityAuditLogs SecurityAuditLog[] @relation("DeviceAuditLogs")
  threatAlerts ThreatAlert[] @relation("DeviceThreatAlerts")
  supportTickets SupportTicket[]
  diagnosticReports DiagnosticReport[]
  predictiveAlerts PredictiveAlert[]
  hardwareEncoders HardwareEncoder[]
  detectedGames    DetectedGame[]
  clusterNodes ClusterNode[] @relation("DeviceClusterNodes")
  meshNode     MeshNode?
  sessions     Session[] @relation("DeviceSessions")
  remoteShellSessions RemoteShellSession[] @relation("DeviceRemoteShellSessions")
  tags DeviceTag[] @relation("DeviceTags")
  hardwareInventory HardwareInventory? @relation("DeviceHardwareInventory")
  dockerContainers DockerContainer[] @relation("DeviceDockerContainers")
  groupId      String?
  group        DeviceGroup? @relation("GroupDevices", fields: [groupId], references: [id], onDelete: SetNull)
  metrics      DeviceMetrics[] @relation("DeviceMetrics")
  incidents    Incident[]   @relation("DeviceIncidents")
}

model DeviceTrust {
  id              String   @id @default(uuid())
  deviceId        String   @unique
  status          String   @default("untrusted")
  reason          String?
  trustedAt       DateTime?
  revokedAt       DateTime?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
  @@index([updatedByUserId, updatedAt])
}

model DeviceAccessPolicy {
  id                       String   @id @default(uuid())
  deviceId                 String   @unique
  unattendedAccessEnabled  Boolean  @default(false)
  remoteInputEnabled       Boolean  @default(false)
  clipboardSyncEnabled     Boolean  @default(false)
  fileTransferEnabled      Boolean  @default(false)
  requiresSessionApproval  Boolean  @default(true)
  maxSessionMinutes        Int      @default(60)
  updatedByUserId          String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  device                   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([unattendedAccessEnabled, updatedAt])
  @@index([remoteInputEnabled, updatedAt])
  @@index([updatedByUserId, updatedAt])
}

model DeviceCommand {
  id             String   @id @default(uuid())
  deviceId       String
  issuedByUserId String?
  type           String   @default("command")
  status         String   @default("pending")
  payload        Json?
  result         Json?
  issuedAt       DateTime @default(now())
  expiresAt      DateTime @default(now())
  deliveredAt    DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  commandName    String?
  params         Json?

  device         Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  issuedBy       User?    @relation("IssuedDeviceCommands", fields: [issuedByUserId], references: [id], onDelete: Cascade)

  @@index([deviceId, status, expiresAt])
  @@index([issuedByUserId, createdAt])
}

model DeviceAuditEvent {
  id          String   @id @default(uuid())
  deviceId    String
  actorUserId String?
  type        String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  actor       User?    @relation("DeviceAuditActors", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([deviceId, createdAt])
  @@index([actorUserId, createdAt])
}

model LaunchCheck {
  id              String   @id @default(uuid())
  key             String   @unique
  area            String
  label           String
  status          String   @default("fail")
  required        Boolean  @default(true)
  notes           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy       User?    @relation("LaunchCheckCreators", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([area, status])
  @@index([createdByUserId, createdAt])
}

model ReleaseCandidate {
  id                 String   @id @default(uuid())
  version            String
  gitSha             String
  status             String   @default("draft")
  signedDesktopBuild Boolean  @default(false)
  migrationsReviewed Boolean  @default(false)
  smokeTestsPassed   Boolean  @default(false)
  notes              String?
  createdByUserId    String?
  promotedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdBy          User?    @relation("ReleaseCandidateCreators", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvals          RolloutApproval[]
  migrationChecks    MigrationCheck[]

  @@unique([version, gitSha])
  @@index([status, createdAt])
  @@index([createdByUserId, createdAt])
}

model RolloutApproval {
  id                 String   @id @default(uuid())
  releaseCandidateId String?
  requestedByUserId  String?
  area               String
  decision           String   @default("pending")
  reason             String?
  decidedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  releaseCandidate   ReleaseCandidate? @relation(fields: [releaseCandidateId], references: [id], onDelete: Cascade)
  requestedBy         User?    @relation("RolloutApprovalActors", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([releaseCandidateId, decision])
  @@index([requestedByUserId, createdAt])
}

model MigrationCheck {
  id                 String   @id @default(uuid())
  releaseCandidateId String?
  name               String
  risk               String
  touchesAuth        Boolean  @default(false)
  touchesBilling     Boolean  @default(false)
  reviewed           Boolean  @default(false)
  destructive        Boolean  @default(false)
  backfillRows       Int      @default(0)
  status             String   @default("pending")
  notes              String?
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  releaseCandidate   ReleaseCandidate? @relation(fields: [releaseCandidateId], references: [id], onDelete: Cascade)
  createdBy          User?    @relation("MigrationCheckCreators", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([releaseCandidateId, status])
  @@index([risk, reviewed])
  @@index([createdByUserId, createdAt])
}

model SupportEscalation {
  id               String   @id @default(uuid())
  title            String
  priority         String
  category         String
  target           String
  status           String   @default("open")
  description      String?
  createdByUserId  String?
  assignedToUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy        User?    @relation("SupportEscalationCreators", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo       User?    @relation("SupportEscalationAssignees", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([status, priority, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([assignedToUserId, createdAt])
}

model ConnectorDefinition {
  id           String   @id @default(uuid())
  key          String   @unique
  name         String
  category     String
  availability String   @default("available")
  description  String
  capabilities Json
  docsUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  installations ConnectorInstallation[]
  auditEvents   ConnectorAuditEvent[]

  @@index([category, availability])
}

model ConnectorInstallation {
  id           String   @id @default(uuid())
  connectorKey String
  userId       String
  status       String   @default("installed")
  installedAt  DateTime @default(now())
  uninstalledAt DateTime?
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connector    ConnectorDefinition @relation(fields: [connectorKey], references: [key], onDelete: Cascade)
  user         User     @relation("ConnectorInstallationUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectorKey, userId])
  @@index([userId, status])
  @@index([connectorKey, status])
}

model ConnectorAuditEvent {
  id           String   @id @default(uuid())
  connectorKey String
  userId       String?
  type         String
  message      String
  metadata     Json?
  createdAt    DateTime @default(now())

  connector    ConnectorDefinition @relation(fields: [connectorKey], references: [key], onDelete: Cascade)
  user         User?    @relation("ConnectorAuditActors", fields: [userId], references: [id], onDelete: SetNull)

  @@index([connectorKey, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Session {
  id        String        @id @default(uuid())
  hostId    String
  clientId  String
  deviceId  String?
  status    SessionStatus @default(PENDING)
  startedAt DateTime?
  endedAt   DateTime?
  duration  Int?
  createdAt DateTime      @default(now())
  recordingUrl String?

  host      User          @relation("HostSessions", fields: [hostId], references: [id])
  client    User          @relation("ClientSessions", fields: [clientId], references: [id])
  sessionReplay SessionReplay?
  gamingSession     GamingSession?
  performanceSnaps  PerformanceSnapshot[]
  device    Device?       @relation("DeviceSessions", fields: [deviceId], references: [id])
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Unified Communications Models

model Ticket {
  id            String    @id @default(uuid())
  customerId    String
  assignedToId  String?
  subject       String
  status        String    @default("open") // open, pending, resolved, closed
  priority      String    @default("medium") // critical, high, medium, low
  channel       String    @default("chat") // chat, email, whatsapp, telegram, sms, messenger, instagram, twitter, voip
  slaResponseAt DateTime?
  slaResolveAt  DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resolvedAt    DateTime?
  sentiment     String? // positive, neutral, negative
  viewingAgentId String?

  customer      User      @relation("TicketCustomer", fields: [customerId], references: [id])
  assignee      User?     @relation("TicketAssignee", fields: [assignedToId], references: [id])
  messages      Message[]
  attachments   Attachment[]
}

model Message {
  id          String    @id @default(uuid())
  ticketId    String
  senderId    String
  body        String
  isInternal  Boolean   @default(false)
  channel     String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  translatedBody String?
  sentiment   String? // positive, neutral, negative

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [senderId], references: [id])
  attachments Attachment[]
}

model Attachment {
  id          String    @id @default(uuid())
  ticketId    String?
  messageId   String?
  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String
  createdAt   DateTime  @default(now())

  ticket      Ticket?   @relation(fields: [ticketId], references: [id])
  message     Message?  @relation(fields: [messageId], references: [id])
}

model KBArticle {
  id          String    @id @default(uuid())
  authorId    String
  title       String
  content     String
  category    String
  language    String    @default("en")
  status      String    @default("draft") // draft, published
  views       Int       @default(0)
  helpfulness Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id])
}

model AutomationRule {
  id          String    @id @default(uuid())
  userId      String
  name        String
  description String?
  trigger     String
  conditions  Json
  actions     Json
  isActive    Boolean   @default(true)
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
}

model CannedResponse {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  macros    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model IVRFlow {
  id        String   @id @default(uuid())
  userId    String
  name      String
  flowConfig Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model TeamChannel {
  id          String    @id @default(uuid())
  name        String
  description String?
  creatorId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator     User      @relation("ChannelCreator", fields: [creatorId], references: [id])
  members     TeamChannelMember[]
}

model TeamChannelMember {
  id          String   @id @default(uuid())
  channelId   String
  userId      String
  joinedAt    DateTime @default(now())

  channel     TeamChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SessionStatus {
  PENDING
  ACTIVE
  ENDED
  REJECTED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}
model DeviceFingerprint {
  id                String    @id @default(uuid())
  deviceId          String    @unique
  hardwareId        String    @unique
  tpmHash           String?
  secureBootEnabled Boolean   @default(false)
  osVersion         String
  macAddress        String?
  approved          Boolean   @default(false)
  approvedByUserId  String?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  device            Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  approvedBy        User?     @relation("DeviceApprovals", fields: [approvedByUserId], references: [id], onDelete: SetNull)
}

model GeoFencePolicy {
  id        String   @id @default(uuid())
  name      String
  action    String   @default("block") // "block" | "alert"
  countries Json     // Array of country codes
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── IoT & Smart Device Remote Management ────────────────────────────────────

model IoTSite {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  location      String?
  timezone      String   @default("UTC")
  latitude      Float?
  longitude     Float?
  isDefault     Boolean  @default(false)
  agentDeviceId String?

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices  IoTDevice[]
  alerts   IoTAlert[]
  tunnels  IoTTunnel[]
  entities SmartHomeEntity[]
  tasks    IoTScheduledTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ZeroTrustPolicy {
  id                    String   @id @default(uuid())
  name                  String
  requireMfa            Boolean  @default(true)
  requireApprovedDevice Boolean  @default(true)
  maxRiskScore          Int      @default(50)
  allowedHoursStart     String?  // e.g. "09:00"
  allowedHoursEnd       String?  // e.g. "17:00"
  dlpEnabled            Boolean  @default(true)
  watermarkEnabled      Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SecurityAuditLog {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  action       String
  userId       String?
  deviceId     String?
  ipAddress    String?
  location     String?
  riskScore    Int      @default(0)
  details      Json?
  previousHash String?
  hash         String
  user         User?    @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  device       Device?  @relation("DeviceAuditLogs", fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([timestamp])
}

model ThreatAlert {
  id          String    @id @default(uuid())
  type        String    // "login_anomaly", "dlp_violation", "geo_fence_violation", "tpm_mismatch"
  severity    String    // "low", "medium", "high", "critical"
  description String
  userId      String?
  deviceId    String?
  ipAddress   String?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  user        User?     @relation("UserThreatAlerts", fields: [userId], references: [id], onDelete: SetNull)
  device      Device?   @relation("DeviceThreatAlerts", fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([resolved])
}

model SupportTicket {
  id           String   @id @default(uuid())
  title        String
  description  String?
  status       String   @default("open")
  priority     String   @default("medium")
  deviceId     String
  userId       String
  aiSummary    String?
  aiResolution String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnostics  DiagnosticReport[]

  @@index([deviceId])
  @@index([userId])
}

model DiagnosticReport {
  id                 String   @id @default(uuid())
  deviceId           String
  ticketId           String?
  cpuStatus          String
  memoryStatus       String
  diskStatus         String
  networkStatus      String
  securityStatus     String
  aiAnalysis         String
  recommendedActions String
  createdAt          DateTime @default(now())

  device             Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ticket             SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([ticketId])
}

model SessionReplay {
  id         String   @id @default(uuid())
  sessionId  String   @unique
  eventsJson String
  aiSummary  String?
  createdAt  DateTime @default(now())

  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model PredictiveAlert {
  id                   String   @id @default(uuid())
  deviceId             String
  component            String
  predictedFailureDate DateTime?
  confidenceScore      Float
  reasoning            String
  isResolved           Boolean  @default(false)
  createdAt            DateTime @default(now())

  device               Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

// ─── Cloud Gaming & High-Performance Streaming ───────────────────────────────

model StreamingProfile {
  id              String   @id @default(cuid())
  userId          String
  name            String
  codec           String   @default("h264")
  encoder         String   @default("software")
  resolution      String   @default("1920x1080")
  framerate       Int      @default(60)
  bitrate         Int      @default(20000)
  minBitrate      Int      @default(5000)
  maxBitrate      Int      @default(50000)
  adaptiveBitrate Boolean  @default(true)
  hdrEnabled      Boolean  @default(false)
  hdrFormat       String?
  audioChannels   Int      @default(2)
  audioCodec      String   @default("opus")
  latencyMode     String   @default("balanced")
  roiEnabled      Boolean  @default(false)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HardwareEncoder {
  id          String   @id @default(cuid())
  deviceId    String
  type        String
  name        String
  vendor      String
  codecs      String   @default("[]")
  maxWidth    Int      @default(3840)
  maxHeight   Int      @default(2160)
  maxFps      Int      @default(60)
  available   Boolean  @default(true)
  detectedAt  DateTime @default(now())
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model DetectedGame {
  id                 String   @id @default(cuid())
  deviceId           String
  name               String
  processName        String
  platform           String   @default("unknown")
  isRunning          Boolean  @default(false)
  lastSeen           DateTime @default(now())
  recommendedProfile String?
  device             Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model GamingSession {
  id                   String    @id @default(cuid())
  sessionId            String    @unique
  profileId            String?
  encoderUsed          String?
  avgFps               Float?
  avgLatency           Float?
  avgBitrate           Int?
