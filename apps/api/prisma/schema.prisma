  userId          String
  date            DateTime @default(now())
  durationMinutes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserScreenTimeLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Incident {
  id            String    @id @default(uuid())
  deviceId      String
  issueType     String
  description   String?
  status        String    @default("open")
  priority      String?
  detectedBy    String?
  resolvedBy    String?
  resolution    String?
  resolvedAt    DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  device        Device    @relation("DeviceIncidents", fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model SecurityIncident {
  id          String    @id @default(uuid())
  deviceId    String?
  title       String    @default("Security Alert")
  threatType  String?
  severity    String?
  source      String?
  status      String    @default("open")
  description String?
  mitigatedBy String?
  mitigatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DeviceQuarantine {
  id            String   @id @default(uuid())
  deviceId      String
  reason        String
  status        String   @default("active")
  quarantinedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model KnowledgeBaseEntry {
  id        String   @id @default(uuid())
  issueType String
  metadata  Json
  solution  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationPolicy {
  id          String   @id @default(uuid())
  actionType  String   @unique
  autoApprove Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id             String   @id @default(uuid())
  type           String
  title          String
  message        String
  priority       String
  requiresAction Boolean  @default(false)
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}





