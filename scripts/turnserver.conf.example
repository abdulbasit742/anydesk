# TURN Server Configuration
listening-port=3478
tls-listening-port=5349
alt-listening-port=3479
alt-tls-listening-port=5350

listening-ip=0.0.0.0
relay-ip=0.0.0.0
external-ip=YOUR_EXTERNAL_IP

min-port=10000
max-port=20000

fingerprint
use-auth-secret
static-auth-secret=CHANGE_THIS_SECRET
realm=remotedesk.io

cert=/etc/letsencrypt/live/remotedesk.io/cert.pem
pkey=/etc/letsencrypt/live/remotedesk.io/privkey.pem

cipher-list="ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512"

denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255

no-cli
no-loopback-peers
no-multicast-peers

log-file=/var/log/turnserver.log
simple-log
