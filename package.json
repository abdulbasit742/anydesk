{
  "name": "remotedesk",
  "version": "0.1.0",
  "private": true,
  "description": "RemoteDesk full-stack SaaS remote desktop starter.",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/desktop",
    "packages/shared",
    "packages/client-sdk"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@remotedesk/api",
    "dev:web": "npm run dev --workspace=@remotedesk/web",
    "dev:desktop": "npm run dev --workspace=@remotedesk/desktop",
    "build:client-sdk": "npm run build --workspace=@remotedesk/client-sdk",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "env:validate": "node scripts/validate-env.mjs",
    "env:validate:strict": "node scripts/validate-env.mjs --strict",
    "security:scan": "node scripts/security-scan.mjs",
    "safety:scan": "node scripts/safety-scan.mjs",
    "socket-gates:check": "node scripts/check-socket-gates.mjs",
    "socket-async:check": "node scripts/check-socket-async-handlers.mjs",
    "runtime-env:check": "node scripts/check-runtime-env-hardening.mjs",
    "cors:check": "node scripts/check-cors-hardening.mjs",
    "auth:check": "node scripts/check-auth-hardening.mjs",
    "api-errors:check": "node scripts/check-api-error-handling.mjs",
    "content-type:check": "node scripts/check-json-content-type.mjs",
    "async-routes:check": "node scripts/check-async-route-handlers.mjs",
    "connectors:check": "node scripts/check-connector-routes.mjs",
    "no-store:check": "node scripts/check-no-store-auth.mjs",
    "rate-limit:check": "node scripts/check-rate-limit-hardening.mjs",
    "trace:check": "node scripts/check-request-id-hardening.mjs",
    "security-headers:check": "node scripts/check-security-headers.mjs",
    "server-timeouts:check": "node scripts/check-server-timeouts.mjs",
    "shutdown:check": "node scripts/check-graceful-shutdown.mjs",
    "dependency-readiness:check": "node scripts/check-dependency-readiness.mjs",
    "ci:local": "npm run env:validate && npm run security:scan && npm run safety:scan && npm run socket-gates:check && npm run socket-async:check && npm run runtime-env:check && npm run cors:check && npm run auth:check && npm run api-errors:check && npm run content-type:check && npm run async-routes:check && npm run connectors:check && npm run no-store:check && npm run rate-limit:check && npm run trace:check && npm run security-headers:check && npm run server-timeouts:check && npm run shutdown:check && npm run dependency-readiness:check && npm run typecheck && npm run build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "7zip-bin": "^5.1.1",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "tsx": "^4.22.4"
  }
}
