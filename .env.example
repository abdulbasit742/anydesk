# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from your Supabase dashboard › Settings › API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key (safe to expose client-side)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App meta ─────────────────────────────────────────────────────────────────
# Used in <title> tags and meta descriptions
VITE_APP_NAME=AgentFlow

# Base URL used for OG/social meta tags (no trailing slash)
VITE_APP_URL=https://agentflow.io

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" to show the AI Insights telemetry panel
VITE_FEATURE_AI_INSIGHTS=true

# Set to "true" to enable the experimental Smart Router
VITE_FEATURE_SMART_ROUTER=true

# Set to "true" to enable live activity WebSocket ticker
VITE_FEATURE_LIVE_TICKER=true

# ─── Billing / Stripe (optional) ─────────────────────────────────────────────
# Publishable key — safe to expose client-side
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx

# ─── Analytics (optional) ────────────────────────────────────────────────────
# PostHog project API key for product analytics
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Dev-only overrides ───────────────────────────────────────────────────────
# Uncomment to bypass auth on local dev (never commit with true)
# VITE_DEV_BYPASS_AUTH=true
