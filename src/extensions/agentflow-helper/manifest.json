{
  "manifest_version": 3,
  "name": "AgentFlow Handoff Companion",
  "version": "1.0.0",
  "description": "Monitors and automates credit-based handoffs on Claude, ChatGPT, and Gemini web platforms.",
  "permissions": ["activeTab", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chat.openai.com/*", "https://chatgpt.com/*", "https://gemini.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
